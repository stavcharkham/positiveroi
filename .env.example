# PositiveROI environment — copy to apps/web/.env.local and fill in.

# Your Supabase project URL (Settings -> API).
NEXT_PUBLIC_SUPABASE_URL=

# The anon/publishable key. Safe to expose to the browser; RLS is the boundary.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service-role key. SERVER ONLY — never expose to the browser.
# All writes and aggregate reads run through this key behind auth guards.
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this app (used in snippets and links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# hosted | self-hosted. Controls hosted-only surfaces like /admin.
NEXT_PUBLIC_DEPLOYMENT=hosted

# Comma-separated emails granted /admin access on the hosted deployment.
HOSTED_ADMIN_EMAILS=
