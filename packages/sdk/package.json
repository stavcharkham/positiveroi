{
  "name": "@positiveroi/sdk",
  "version": "0.1.0",
  "description": "Tiny browser/node client for logging runs to PositiveROI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@positiveroi/core": "workspace:*",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
